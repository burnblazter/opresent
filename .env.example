#--------------------------------------------------------------------
# Example Environment Configuration
# Rename this file to .env and fill in your values.
# See INSTALL.md for full setup guide.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = production
app.appTimezone = 'Asia/Makassar'

#--------------------------------------------------------------------
# APP
# Local (Laragon) : http://presensi.test/
# Production (cPanel) : https://yourdomain.com/
#--------------------------------------------------------------------
app.baseURL = 'https://yourdomain.com/'

#--------------------------------------------------------------------
# GROQ API CONFIGURATION
# Get your API key at: https://console.groq.com/keys
#--------------------------------------------------------------------
GROQ_API_KEYS=your_groq_api_key
GROQ_MODEL=moonshotai/kimi-k2-instruct-0905

#--------------------------------------------------------------------
# TELEGRAM BOT CONFIG
# Bot token from @BotFather, Chat ID from your group
#--------------------------------------------------------------------
telegram.botToken = 'your_telegram_bot_token'
telegram.chatId   = 'your_telegram_chat_id'

#--------------------------------------------------------------------
# EMAIL / SMTP CONFIGURATION
#--------------------------------------------------------------------

EMAIL_FROM_ADDRESS = your_email_address_here
EMAIL_FROM_NAME    = "Your Name or App Name Here"

EMAIL_SMTP_HOST    = smtp.gmail.com
EMAIL_SMTP_USER    = your_smtp_email_address_here
EMAIL_SMTP_PASS    = "your_google_app_password_here"
EMAIL_SMTP_PORT    = 465
EMAIL_SMTP_CRYPTO  = ssl
EMAIL_SMTP_TIMEOUT = 60

#--------------------------------------------------------------------
# DATABASE
# Local (Laragon) : username=root, password=(leave blank)
# Production (cPanel) : use credentials from MySQL Databases menu
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = your_database_name
database.default.username = your_database_username
database.default.password = your_database_password
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306
